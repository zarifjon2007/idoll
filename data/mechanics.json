{
  "check_stress_threshold": {
    "id": "check_stress_threshold",
    "text": "[i](System: Emergency Vitals Scan...)[/i]",
    "conditionals": [
      {
        "type": "conditional",
        "branches": [
          {
            "condition": "physical <= 0",
            "type": "if",
            "content": "",
            "goto": "total_body_failure"
          },
          {
            "condition": "stress >= 85",
            "type": "elseif",
            "content": "",
            "goto": "severe_breakdown"
          },
          {
            "condition": "stress >= 65",
            "type": "elseif",
            "content": "",
            "goto": "mild_burnout"
          },
          {
            "condition": "physical <= 15",
            "type": "elseif",
            "content": "",
            "goto": "physical_injury"
          },
          {
            "condition": null,
            "type": "else",
            "content": "",
            "goto": null
          }
        ]
      }
    ]
  },
  "total_body_failure": {
    "id": "total_body_failure",
    "text": "Everything goes dark. You don't even feel your body hitting the floor.\nYou wake up three days later in a private clinic. A manager is sitting by your bed, looking at a tablet. \"You missed seventy-two hours of training,\" he says coldly. \"The CEO is considering replacing you. You are a liability now.\"\n*set physical 25\n*set stress 50\n*set dance %-20\n*set vocals %-20\n*set charisma %-20\n*set visual %-10\n*set self_belief %-20\n*set rel_manager %-25\n*set collapse_count +1\n[b]CRITICAL PENALTY: Massive Stat Loss (-20%). Manager trust is broken.[/b]"
  },
  "severe_breakdown": {
    "id": "severe_breakdown",
    "text": "Your body refuses to obey. It's a total system shutdown.\nYou wake up in the infirmary with an IV drip in your arm.\n\"Disappointing,\" Director Park says. \"Take 3 days off.\"\n*set physical %+15\n*set stress %-20\n*set dance %-12\n*set vocals %-12\n*set charisma %-12\n*set self_belief %-10\n*set rel_manager %-15\n[b]MAJOR PENALTY: -12% to All Skills due to Hospitalization.[/b]"
  },
  "mild_burnout": {
    "id": "mild_burnout",
    "text": "The exhaustion is catching up to you. Your mind feels like it's full of fog.\n\"Focus!\" the instructor yells. \"${name}, you're dragging behind!\"\n*set dance %-5\n*set vocals %-5\n*set self_belief %-5\n[b]PENALTY: -5% to Skills due to Brain Fog.[/b]"
  },
  "physical_injury": {
    "id": "physical_injury",
    "text": "SNAP. A sharp pain shoots through your leg. You have a stress fracture.\nYou are forced to sit out of dance practice for a week.\n*set dance %-15\n*set physical %+10\n*set stress %+10\n[b]PENALTY: -15% to Dance. Stress Increased.[/b]"
  },
  "update_mental_state": {
    "id": "update_mental_state",
    "text": "",
    "conditionals": [
      {
        "branches": []
      },
      {
        "type": "conditional",
        "branches": [
          {
            "condition": "the_mask >= 60",
            "type": "if",
            "content": "*set mental_state \"Dissociated\"",
            "goto": null
          },
          {
            "condition": "ruthless >= 60",
            "type": "elseif",
            "content": "*set mental_state \"Manic\"",
            "goto": null
          },
          {
            "condition": "per_gentle >= 60",
            "type": "elseif",
            "content": "*set mental_state \"Depressed\"",
            "goto": null
          },
          {
            "condition": null,
            "type": "else",
            "content": "*set mental_state \"Burnout\"",
            "goto": null
          },
          {
            "condition": "stress < 70) and (trauma_points < 3",
            "type": "if",
            "content": "*set mental_state \"Stable\"",
            "goto": null
          }
        ]
      }
    ]
  },
